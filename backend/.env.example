# Exchange API Keys (leave empty to use paper trading only)
EXCHANGE_NAME=binance
API_KEY=
API_SECRET=

# Paper Trading (set to false ONLY when ready for live trading)
PAPER_TRADING=true

# ── Security ─────────────────────────────────────────────────────────────────
# Full JWT login system (recommended for any shared/server use)
# Step 1: Set an admin username (default: admin)
ADMIN_USERNAME=admin
# Step 2: Generate a bcrypt hash: python generate-password-hash.py
ADMIN_PASSWORD_HASH=
# Step 3: Generate a stable JWT secret (required — otherwise sessions reset on restart)
# Generate one: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=

# ── Field-level Encryption ────────────────────────────────────────────────────
# Encrypts sensitive database columns (signal_features, notes) using Fernet.
# Generate a key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Leave EMPTY to store fields as plain text (default).
FIELD_ENCRYPTION_KEY=

# ── HTTPS / TLS ───────────────────────────────────────────────────────────────
# Point to cert files generated by: python generate-certs.py
# Leave EMPTY to use plain HTTP (fine for localhost-only use).
SSL_CERTFILE=
SSL_KEYFILE=

# Server binding — NEVER change to 0.0.0.0 unless behind a reverse proxy + firewall
HOST=127.0.0.1
PORT=8000

# Set to true to expose /docs, /redoc and /openapi.json (development only)
ENABLE_DOCS=false

# Set to true to enable auto-reload on code changes (development only)
RELOAD=false

# Risk Settings
MAX_PORTFOLIO_RISK_PERCENT=2.0
MAX_DRAWDOWN_PERCENT=10.0
DEFAULT_STOP_LOSS_PERCENT=2.0
DEFAULT_TAKE_PROFIT_PERCENT=4.0
MAX_CONCURRENT_POSITIONS=5

# Starting paper balance (USD)
PAPER_BALANCE=10000.0

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./trading_bot.db
