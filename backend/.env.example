# Exchange API Keys (leave empty to use paper trading only)
EXCHANGE_NAME=binance
API_KEY=
API_SECRET=

# Paper Trading (set to false ONLY when ready for live trading)
PAPER_TRADING=true

# ── Security ─────────────────────────────────────────────────────────────────
# Set a strong random token to protect all API endpoints and WebSocket.
# Leave EMPTY to disable auth (local-only dev mode, host=127.0.0.1 only).
# Generate one: python -c "import secrets; print(secrets.token_hex(32))"
API_SECRET_TOKEN=

# Server binding — NEVER change to 0.0.0.0 unless behind a reverse proxy + firewall
HOST=127.0.0.1
PORT=8000

# Set to true to expose /docs, /redoc and /openapi.json (development only)
ENABLE_DOCS=false

# Set to true to enable auto-reload on code changes (development only)
RELOAD=false

# Risk Settings
MAX_PORTFOLIO_RISK_PERCENT=2.0
MAX_DRAWDOWN_PERCENT=10.0
DEFAULT_STOP_LOSS_PERCENT=2.0
DEFAULT_TAKE_PROFIT_PERCENT=4.0
MAX_CONCURRENT_POSITIONS=5

# Starting paper balance (USD)
PAPER_BALANCE=10000.0

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./trading_bot.db
